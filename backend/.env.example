# Server
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/employee_movement_ai?schema=public"

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_NAME=emai_session
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# File storage. STORAGE_DRIVER=local|s3
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./uploads
PUBLIC_UPLOADS_BASE_URL=http://localhost:4000/uploads

# S3-compatible storage (used when STORAGE_DRIVER=s3)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# AI extraction (Claude). If unset, extraction runs in mock mode.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Single-service deployment: absolute path to the built frontend (dist). When
# set, the API also serves the web UI. Leave blank for local dev (Vite serves it).
FRONTEND_DIST=

# Path to a Chromium/Chrome binary for the PDF engine. Leave blank locally
# (Puppeteer uses its bundled Chromium); set in Docker/production.
PUPPETEER_EXECUTABLE_PATH=
